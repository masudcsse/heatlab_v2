# Rename this file to .env and add your real key.
# In Vite, environment variables must start with VITE_

VITE_GOOGLE_PLACES_API_KEY=your_google_api_key

# Optional backend URL for future real Netatmo integration.
# The frontend should NOT store Netatmo client secret or access tokens.
VITE_API_BASE_URL=http://localhost:5000
